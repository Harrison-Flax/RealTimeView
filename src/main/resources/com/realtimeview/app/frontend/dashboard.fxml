<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.realtimeview.app.frontend.controller.DashboardController"
            prefWidth="1200" prefHeight="800">

    <!-- Top Navigation Bar -->
    <top>
        <HBox spacing="20" style="-fx-padding: 15; -fx-background-color: #1a1a2e;">
            <Label text="RealTimeView" style="-fx-font-size: 20; -fx-text-fill: white; -fx-font-weight: bold;"/>
            <!-- Tab buttons to switch between stocks, crypto, news -->
            <Button text="Stocks" onAction="#showStocks" style="-fx-background-color: #4ecca3; -fx-text-fill: black;"/>
            <Button text="Crypto" onAction="#showCrypto" style="-fx-background-color: #4ecca3; -fx-text-fill: black;"/>
            <Button text="News" onAction="#showNews" style="-fx-background-color: #4ecca3; -fx-text-fill: black;"/>
            <Button text="Refresh" onAction="#refreshData" style="-fx-background-color: #4ecca3; -fx-text-fill: black;"/>
        </HBox>
    </top>

    <!-- Main Content Area With Tables -->
    <center>
        <VBox spacing="10" style="-fx-padding: 20;">
            <Label fx:id="statusLabel" text="Loading..." style="-fx-text-fill: gray;"/>

            <TableView fx:id="stockTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="tickerCol" text="Ticker" prefWidth="100"/>
                    <TableColumn fx:id="nameCol" text="Name" prefWidth="200"/>
                    <TableColumn fx:id="priceCol" text="Price" prefWidth="120"/>
                    <TableColumn fx:id="changeCol" text="Change" prefWidth="120"/>
                    <TableColumn fx:id="changePercentCol" text="Change %" prefWidth="120"/>
                </columns>
            </TableView>

        <TableView fx:id="cryptoTable" visible="false" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="nameCryptoCol" text="Name" prefWidth="100"/>
                    <TableColumn fx:id="symbolCryptoCol" text="Symbol" prefWidth="200"/>
                    <TableColumn fx:id="priceUsdCryptoCol" text="Price" prefWidth="120"/>
                    <TableColumn fx:id="marketCapCryptoCol" text="Market Cap" prefWidth="120"/>
                    <TableColumn fx:id="changePercent24hCryptoCol" text="Change %" prefWidth="120"/>
                </columns>
            </TableView>

            <TableView fx:id="newsTable" visible="false" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="headlineCol" text="Headline" prefWidth="100"/>
                    <TableColumn fx:id="summaryCol" text="Summary" prefWidth="200"/>
                    <TableColumn fx:id="sourceCol" text="Source" prefWidth="120"/>
                    <TableColumn fx:id="categoryCol" text="Category" prefWidth="120"/>
                    <TableColumn fx:id="publishedAtCol" text="Published At" prefWidth="120"/>
                </columns>
            </TableView>
        </VBox>
    </center>

    <!-- Status Bar At Bottom -->
    <bottom>
        <HBox style="-fx-padding: 10; -fx-background-color: #1a1a2e;">
            <Label fx:id="lastUpdatedLabel" text="Last updated: --"
                   style="-fx-text-fill: gray; -fx-font-size: 11;"/>
        </HBox>
    </bottom>

</BorderPane>